{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run launch-deptrac",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run launch-staged:tests",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
